# Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB Connection String
# Option 1: Local MongoDB (if running locally)
# MONGODB_URI=mongodb://localhost:27017/rental-management

# Option 2: MongoDB Atlas (Cloud)
MONGODB_URI=mongodb+srv://rental_db:rental-db-2026@cluster0.lylhfb9.mongodb.net/rental-db?appName=Cluster0
# ============================================
# SERVER CONFIGURATION
# ============================================

# Server Port
PORT=8000

# Node Environment
NODE_ENV=development

# ============================================
# SECURITY
# ============================================

# Allowed CORS origins (comma-separated list)
# Example: CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ORIGINS=

# JSON request body size limit
REQUEST_BODY_LIMIT=1mb

# Rate limiting (in milliseconds / requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=20

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret Key (Change this to something secure!)
JWT_SECRET=rental-secret-2026

# JWT Token Expiration Time
JWT_EXPIRES=1d

# ============================================
# FILE UPLOAD
# ============================================

# Directory for storing uploaded files (payment proofs, etc.)
UPLOAD_DIR=./uploads

# ============================================
# ADMIN INITIALIZATION
# ============================================

# Admin Email (used when initializing admin account)
ADMIN_EMAIL=admin@rental.com

# Admin Password (used when initializing admin account)
ADMIN_PASSWORD=admin123

# Admin Name (used when initializing admin account)
ADMIN_NAME=System Admin
