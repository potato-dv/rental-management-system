# Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================
# DATABASE CONFIGURATION
# ============================================

# MongoDB Connection String
# Option 1: Local MongoDB (if running locally)
# MONGODB_URI=mongodb://localhost:27017/rental-management

# Option 2: MongoDB Atlas (Cloud)
MONGODB_URI=mongodb+srv://username:password@clustername.mongodb.net/dbname?appName=Cluster0

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server Port
PORT=8000

# Node Environment
NODE_ENV=development

# ============================================
# AUTHENTICATION
# ============================================

# JWT Secret Key (Change this to something secure!)
JWT_SECRET=your_super_secret_jwt_key_here

# JWT Token Expiration Time
JWT_EXPIRES=7d

# ============================================
# FILE UPLOAD
# ============================================

# Directory for storing uploaded files (payment proofs, etc.)
UPLOAD_DIR=./uploads

# ============================================
# ADMIN INITIALIZATION
# ============================================

# Admin Email (used when initializing admin account)
ADMIN_EMAIL=admin@rental.com

# Admin Password (used when initializing admin account)
ADMIN_PASSWORD=admin123

# Admin Name (used when initializing admin account)
ADMIN_NAME=System Admin
